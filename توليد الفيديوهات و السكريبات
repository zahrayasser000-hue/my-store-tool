import React, { useState, useEffect, useRef } from 'react';
import { Clapperboard, Loader2, Sparkles, Target, Users, PlayCircle, CheckCircle2, AlertTriangle, Video, Mic, Image as ImageIcon, X, Volume2 } from 'lucide-react';

const apiKey = ""; // ⚠️ ضع مفتاح Gemini API الخاص بك هنا

// ------------------------------------------------------------------
// دالة تحويل الصوت من PCM (الذي يرجعه Gemini) إلى ملف WAV قابل للتشغيل
// ------------------------------------------------------------------
function pcmToWav(base64Pcm, sampleRate = 24000) {
  try {
    const binaryString = atob(base64Pcm);
    const pcmBuffer = new Uint8Array(binaryString.length);
    for (let i = 0; i < binaryString.length; i++) pcmBuffer[i] = binaryString.charCodeAt(i);
    const numChannels = 1, bitsPerSample = 16;
    const byteRate = sampleRate * numChannels * (bitsPerSample / 8), blockAlign = numChannels * (bitsPerSample / 8);
    const wavHeader = new ArrayBuffer(44);
    const view = new DataView(wavHeader);
    const writeString = (v, offset, str) => { for (let i = 0; i < str.length; i++) v.setUint8(offset + i, str.charCodeAt(i)); };
    writeString(view, 0, 'RIFF'); view.setUint32(4, 36 + pcmBuffer.byteLength, true); writeString(view, 8, 'WAVE'); writeString(view, 12, 'fmt '); view.setUint32(16, 16, true); view.setUint16(20, 1, true); view.setUint16(22, numChannels, true); view.setUint32(24, sampleRate, true); view.setUint32(28, byteRate, true); view.setUint16(32, blockAlign, true); view.setUint16(34, bitsPerSample, true); writeString(view, 36, 'data'); view.setUint32(40, pcmBuffer.byteLength, true);
    const wavBytes = new Uint8Array(44 + pcmBuffer.byteLength); wavBytes.set(new Uint8Array(wavHeader), 0); wavBytes.set(new Uint8Array(pcmBuffer), 44);
    return new Blob([wavBytes], { type: 'audio/wav' });
  } catch (e) { return null; }
}

export default function App() {
  const [isReady, setIsReady] = useState(false);

  // ⚡️ حقن التصميم الأساسي
  useEffect(() => {
    const loadAssets = () => {
      if (!document.getElementById('cairo-font')) {
        const link = document.createElement('link');
        link.id = 'cairo-font';
        link.href = "https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap";
        link.rel = "stylesheet";
        document.head.appendChild(link);
      }
      if (!document.getElementById('tailwind-script')) {
        const script = document.createElement('script');
        script.id = 'tailwind-script';
        script.src = "https://cdn.tailwindcss.com";
        script.onload = () => {
          if (window.tailwind) {
            window.tailwind.config = { theme: { extend: { fontFamily: { sans: ['Cairo', 'sans-serif'] } } } };
          }
          setIsReady(true);
        };
        document.head.appendChild(script);
      } else { setIsReady(true); }
      document.body.style.backgroundColor = "#020617";
      document.body.style.margin = "0";
    };
    loadAssets();
  }, []);

  const [inputs, setInputs] = useState({
    productName: "",
    targetAudience: "",
    mainBenefit: "",
    videoLength: "قصير (15 ثانية)",
    platform: "TikTok / YouTube Shorts (عمودي)",
    voiceType: "Female"
  });

  const [loading, setLoading] = useState(false);
  const [status, setStatus] = useState("");
  const [error, setError] = useState("");
  
  // مشغل الفيديو المدمج
  const [activeVideo, setActiveVideo] = useState(null);
  const [currentSceneIndex, setCurrentSceneIndex] = useState(0);
  const [imageLoading, setImageLoading] = useState(true);
  const audioRef = useRef(null);

  const handleInputChange = (e) => {
    const { name, value } = e.target;
    setInputs(prev => ({ ...prev, [name]: value }));
  };

  const getPlatformDimensions = () => {
    if (inputs.platform.includes("عمودي")) return { w: 720, h: 1280 };
    if (inputs.platform.includes("مربع")) return { w: 1080, h: 1080 };
    if (inputs.platform.includes("أفقي")) return { w: 1280, h: 720 };
    return { w: 720, h: 1280 }; // افتراضي عمودي
  };

  const generateVideo = async () => {
    const { productName, targetAudience, mainBenefit, videoLength, platform, voiceType } = inputs;
    
    if (!productName || !mainBenefit) {
      return setError("⚠️ الرجاء إدخال اسم المنتج والفائدة الرئيسية لتوجيه المخرج.");
    }

    setLoading(true);
    setError("");
    setActiveVideo(null);
    setStatus("جاري كتابة السيناريو الإعلاني المخصص...");

    const promptText = `
    أنت مخرج إعلانات ومسوق فيروسي لمنصة ${platform}.
    اكتب سكربت فيديو مدته ${videoLength} لمنتج "${productName}".
    الجمهور: ${targetAudience}. الفائدة: ${mainBenefit}.
    
    رد بـ JSON فقط:
    {
        "video_title": "عنوان الإعلان",
        "scenes": [
            {"visual_prompt": "وصف دقيق للمشهد باللغة الإنجليزية لتوليد صورة (مثال: realistic commercial photo of a man smiling using a product, 8k resolution)", "audio": "التعليق الصوتي بالعربية الذي سيُقرأ في هذا المشهد"},
            ...
        ]
    }
    `;

    try {
      // 1. توليد السكربت
      const textPayload = {
        contents: [{ parts: [{ text: promptText }] }],
        generationConfig: { responseMimeType: "application/json" }
      };
      
      const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
        method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(textPayload)
      });
      const data = await res.json();
      const scriptJson = JSON.parse(data.candidates?.[0]?.content?.parts?.[0]?.text);
      
      if (!scriptJson || !scriptJson.scenes) throw new Error("فشل في استخراج المشاهد.");

      setStatus("المخرج يعمل: جاري تصميم المشاهد البصرية والتعليق الصوتي بشرياً...");
      const voiceName = voiceType === "Female" ? "Aoede" : "Charon";
      const dims = getPlatformDimensions();

      // 2. توليد الصور والصوت لكل مشهد
      const compiledScenes = await Promise.all(scriptJson.scenes.map(async (scene, index) => {
        // صورة المشهد عبر Pollinations
        const imgUrl = `https://image.pollinations.ai/prompt/${encodeURIComponent(scene.visual_prompt || "product")}?width=${dims.w}&height=${dims.h}&nologo=true&seed=${Math.floor(Math.random() * 10000)}`;
        
        // صوت المشهد (TTS) عبر Gemini
        let audioUrl = null;
        if (scene.audio) {
          try {
            const ttsRes = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent?key=${apiKey}`, {
              method: "POST", headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ 
                contents: [{ parts: [{ text: scene.audio }] }], 
                generationConfig: { responseModalities: ["AUDIO"], speechConfig: { voiceConfig: { prebuiltVoiceConfig: { voiceName } } } }, 
                model: "gemini-2.5-flash-preview-tts" 
              })
            });
            const ttsData = await ttsRes.json();
            const pcmBase64 = ttsData.candidates?.[0]?.content?.parts?.[0]?.inlineData?.data;
            if (pcmBase64) audioUrl = URL.createObjectURL(pcmToWav(pcmBase64, 24000));
          } catch (e) { console.error("TTS Error", e); }
        }
        return { ...scene, imgUrl, audioUrl };
      }));

      setActiveVideo({ title: scriptJson.video_title, scenes: compiledScenes });
      setCurrentSceneIndex(0);
      setImageLoading(true);
      setStatus("");

    } catch (err) {
      setError("حدث خطأ أثناء الإنتاج. تأكد من المفتاح وجرب مرة أخرى.");
      setStatus("");
    }
    setLoading(false);
  };

  // التحكم في تشغيل الفيديو والانتقال التلقائي للمشاهد
  useEffect(() => {
    if (activeVideo && audioRef.current && !imageLoading) {
      if (activeVideo.scenes[currentSceneIndex]?.audioUrl) { 
        audioRef.current.src = activeVideo.scenes[currentSceneIndex].audioUrl; 
        audioRef.current.play().catch(()=>{}); 
      } else { 
        // إذا لم يكن هناك صوت، انتظر 3 ثوانٍ وانتقل للمشهد التالي
        const timer = setTimeout(() => handleAudioEnded(), 3000); 
        return () => clearTimeout(timer); 
      }
    }
  }, [activeVideo, currentSceneIndex, imageLoading]);

  const handleAudioEnded = () => { 
    if (activeVideo && currentSceneIndex < activeVideo.scenes.length - 1) { 
      setImageLoading(true); 
      setCurrentSceneIndex(prev => prev + 1); 
    } 
  };

  if (!isReady) {
    return (
      <div style={{ display: 'flex', flexDirection: 'column', justifyContent: 'center', alignItems: 'center', height: '100vh', backgroundColor: '#0f172a', color: '#ec4899', fontFamily: 'sans-serif' }}>
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className="animate-spin mb-4"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
        <h2 style={{ fontSize: '24px', fontWeight: 'bold', margin: 0 }}>جاري تجهيز استوديو المونتاج...</h2>
      </div>
    );
  }

  // حساب أبعاد المشغل بناءً على المنصة
  const isVertical = inputs.platform.includes("عمودي");
  const isSquare = inputs.platform.includes("مربع");
  const playerClass = isVertical ? "w-[360px] h-[640px]" : (isSquare ? "w-[500px] h-[500px]" : "w-[720px] h-[405px]");

  return (
    <div dir="rtl" className="min-h-screen bg-slate-950 text-slate-200 pb-20 selection:bg-pink-500 selection:text-white">
      
      {/* Header */}
      <div className="bg-gradient-to-br from-slate-900 to-slate-800 border-b-4 border-pink-500 p-8 text-center relative overflow-hidden shadow-2xl">
        <div className="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
        <h1 className="text-4xl md:text-5xl font-black mb-3 flex justify-center items-center gap-3 relative z-10">
          <Video className="w-10 h-10 text-pink-400" />
          <span className="bg-gradient-to-r from-pink-400 to-rose-400 bg-clip-text text-transparent">ALI AI Video Maker</span>
        </h1>
        <p className="text-slate-400 text-lg font-bold relative z-10">توليد فيديوهات إعلانية كاملة (صور + صوت) بالذكاء الاصطناعي</p>
      </div>

      <div className="max-w-7xl mx-auto px-4 sm:px-6 mt-10 flex flex-col lg:flex-row gap-8">
        
        {/* Sidebar: Inputs */}
        <div className="w-full lg:w-1/3 space-y-6">
          <div className="bg-slate-900 border border-slate-800 rounded-3xl p-6 shadow-xl sticky top-6">
            <h2 className="text-xl font-black text-white mb-6 flex items-center gap-2 border-b border-slate-800 pb-4">
              <Target className="w-5 h-5 text-pink-400" /> بيانات الإعلان
            </h2>
            
            <div className="space-y-4">
              <div>
                <label className="block text-xs font-bold text-slate-400 mb-2">اسم المنتج</label>
                <div className="relative">
                  <Sparkles className="absolute right-3 top-3.5 w-5 h-5 text-slate-500" />
                  <input type="text" name="productName" value={inputs.productName} onChange={handleInputChange} className="w-full bg-slate-950 border border-slate-800 rounded-xl py-3 pr-10 pl-4 text-white outline-none focus:border-pink-500 transition-colors" placeholder="مثال: كريم الجبروت" />
                </div>
              </div>
              
              <div>
                <label className="block text-xs font-bold text-slate-400 mb-2">الجمهور المستهدف</label>
                <input type="text" name="targetAudience" value={inputs.targetAudience} onChange={handleInputChange} className="w-full bg-slate-950 border border-slate-800 rounded-xl py-3 px-4 text-white outline-none focus:border-pink-500 transition-colors" placeholder="مثال: رجال في السعودية" />
              </div>

              <div>
                <label className="block text-xs font-bold text-slate-400 mb-2">النتيجة الكبرى (Hook)</label>
                <textarea name="mainBenefit" value={inputs.mainBenefit} onChange={handleInputChange} className="w-full h-20 bg-slate-950 border border-slate-800 rounded-xl py-3 px-4 text-white outline-none focus:border-pink-500 transition-colors resize-none" placeholder="مثال: نتائج ملموسة وطبيعية بسرعة" />
              </div>

              <div className="grid grid-cols-1 gap-4 pt-2">
                <div>
                  <label className="block text-xs font-bold text-slate-400 mb-2">المنصة (يحدد مقاس الفيديو)</label>
                  <select name="platform" value={inputs.platform} onChange={handleInputChange} className="w-full bg-slate-950 border border-slate-800 rounded-xl py-3 px-3 text-white outline-none focus:border-pink-500 text-sm font-bold">
                    <option>TikTok / YouTube Shorts (عمودي)</option>
                    <option>Snapchat (عمودي)</option>
                    <option>Facebook / Instagram (مربع)</option>
                    <option>YouTube Standard (أفقي)</option>
                  </select>
                </div>
                
                <div className="grid grid-cols-2 gap-3">
                  <div>
                    <label className="block text-xs font-bold text-slate-400 mb-2">طول الفيديو</label>
                    <select name="videoLength" value={inputs.videoLength} onChange={handleInputChange} className="w-full bg-slate-950 border border-slate-800 rounded-xl py-3 px-3 text-white outline-none focus:border-pink-500 text-sm">
                      <option>قصير (15 ثانية)</option>
                      <option>متوسط (30 ثانية)</option>
                    </select>
                  </div>
                  <div>
                    <label className="block text-xs font-bold text-slate-400 mb-2">المعلق الصوتي</label>
                    <select name="voiceType" value={inputs.voiceType} onChange={handleInputChange} className="w-full bg-slate-950 border border-slate-800 rounded-xl py-3 px-3 text-white outline-none focus:border-pink-500 text-sm">
                      <option value="Female">أنثى (Aoede)</option>
                      <option value="Male">ذكر (Charon)</option>
                    </select>
                  </div>
                </div>
              </div>
            </div>

            <button 
              onClick={generateVideo} 
              disabled={loading}
              className="w-full mt-8 bg-gradient-to-r from-pink-600 to-rose-600 hover:from-pink-500 hover:to-rose-500 text-white font-black py-4 rounded-xl shadow-lg shadow-pink-600/20 transition-all active:scale-95 flex items-center justify-center gap-2"
            >
              {loading ? <><Loader2 className="w-5 h-5 animate-spin" /> جاري الإنتاج...</> : <><Clapperboard className="w-5 h-5" /> تصوير وإخراج الفيديو المباشر</>}
            </button>
            
            {status && <div className="mt-4 p-3 bg-pink-500/10 text-pink-400 text-xs font-black text-center rounded-xl animate-pulse border border-pink-500/20">{status}</div>}
            {error && <div className="mt-4 p-3 bg-red-500/20 border border-red-500/50 text-red-400 text-xs font-bold rounded-lg flex items-start gap-2"><AlertTriangle className="w-4 h-4 shrink-0" /> {error}</div>}
          </div>
        </div>

        {/* Main Area: Outputs */}
        <div className="w-full lg:w-2/3 space-y-6">
          
          {!activeVideo && !loading && (
            <div className="bg-slate-900 border border-slate-800 rounded-3xl p-12 text-center flex flex-col items-center justify-center min-h-[600px] border-dashed">
              <Video className="w-20 h-20 text-slate-800 mb-6" />
              <h3 className="text-2xl font-black text-slate-300 mb-2">استوديو المونتاج الآلي جاهز</h3>
              <p className="text-slate-500 max-w-md mx-auto leading-relaxed">أدخل بيانات المنتج على اليمين. سيقوم الذكاء الاصطناعي بكتابة السيناريو، رسم المشاهد البصرية، وتوليد التعليق الصوتي لإنتاج فيديو متكامل فوراً!</p>
            </div>
          )}

          {loading && (
            <div className="bg-slate-900 border border-slate-800 rounded-3xl p-12 text-center flex flex-col items-center justify-center min-h-[600px]">
              <Loader2 className="w-16 h-16 text-pink-500 animate-spin mb-6 mx-auto" />
              <h3 className="text-2xl font-black text-white animate-pulse">🎬 المخرج الآلي يعمل...</h3>
              <p className="text-slate-400 mt-4 text-sm font-bold bg-slate-950 p-4 rounded-xl border border-slate-800 flex flex-col gap-2">
                <span className="flex items-center gap-2"><CheckCircle2 className="w-4 h-4 text-emerald-500"/> كتابة السيناريو الخاطف للانتباه</span>
                <span className="flex items-center gap-2"><Loader2 className="w-4 h-4 text-pink-500 animate-spin"/> رسم المشاهد (توليد الصور)</span>
                <span className="flex items-center gap-2"><Loader2 className="w-4 h-4 text-blue-500 animate-spin"/> تسجيل التعليق الصوتي (Voice-over)</span>
              </p>
            </div>
          )}

          {activeVideo && !loading && (
            <div className="bg-slate-900 border border-slate-800 rounded-3xl overflow-hidden shadow-2xl animate-in fade-in duration-700 flex flex-col items-center p-6">
              <div className="w-full flex justify-between items-center mb-6">
                <h2 className="text-xl font-black text-white flex items-center gap-2"><PlayCircle className="text-pink-500"/> معاينة الإعلان: {activeVideo.title}</h2>
                <div className="bg-slate-800 px-4 py-1.5 rounded-full text-xs font-bold text-slate-300">منصة: {inputs.platform}</div>
              </div>

              {/* مشغل الفيديو الافتراضي */}
              <div className={`relative bg-black rounded-[2rem] overflow-hidden border-4 border-slate-800 shadow-2xl flex items-center justify-center ${playerClass}`}>
                
                {/* الصورة الخلفية (تتغير مع كل مشهد) */}
                <img 
                  src={activeVideo.scenes[currentSceneIndex]?.imgUrl} 
                  className={`absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ${imageLoading ? 'opacity-0 scale-105' : 'opacity-100 scale-100'}`} 
                  onLoad={() => setImageLoading(false)} 
                  onError={() => setImageLoading(false)}
                  alt="Video Frame"
                />
                
                {/* تراكب داكن سفلي لقراءة النص */}
                <div className="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent pointer-events-none"></div>

                {/* نص التعليق الصوتي (Subtitle) */}
                <div className="absolute bottom-10 w-full px-6 text-center z-30">
                  <div className="inline-block bg-black/60 backdrop-blur-sm text-white font-black text-lg md:text-xl p-4 rounded-2xl shadow-lg border border-white/10 leading-relaxed">
                    {activeVideo.scenes[currentSceneIndex]?.audio}
                  </div>
                </div>

                {/* شريط التقدم والمؤشرات */}
                <div className="absolute top-4 right-4 flex gap-2 z-30">
                  <div className="bg-red-600/90 text-white text-[10px] font-black px-3 py-1 rounded-full flex items-center gap-1"><div className="w-1.5 h-1.5 bg-white rounded-full animate-pulse"></div> Live Preview</div>
                </div>
                <div className="absolute top-4 left-4 bg-black/60 text-white text-[10px] font-black px-3 py-1 rounded-full z-30 flex items-center gap-1">
                  <Volume2 className="w-3 h-3 text-pink-400" /> المشهد {currentSceneIndex + 1} / {activeVideo.scenes.length}
                </div>

                {/* مؤشر التحميل أثناء جلب الصورة/الصوت للمشهد */}
                {imageLoading && (
                  <div className="absolute inset-0 flex items-center justify-center bg-slate-900/80 z-40 backdrop-blur-sm">
                    <Loader2 className="w-10 h-10 text-pink-500 animate-spin" />
                  </div>
                )}
              </div>

              {/* أزرار التحكم */}
              <div className="flex gap-4 mt-6">
                <button onClick={() => { setCurrentSceneIndex(0); setImageLoading(true); }} className="bg-slate-800 hover:bg-slate-700 text-white px-6 py-3 rounded-xl font-bold flex items-center gap-2 transition-colors">
                  <PlayCircle className="w-5 h-5" /> إعادة التشغيل
                </button>
              </div>

              {/* مشغل الصوت المخفي (للانتقال التلقائي) */}
              <audio ref={audioRef} onEnded={handleAudioEnded} className="hidden" />
              
              {/* السيناريو المكتوب (للمراجعة) */}
              <div className="w-full mt-10 pt-6 border-t border-slate-800">
                <h3 className="text-sm font-bold text-slate-400 mb-4 flex items-center gap-2"><FileText className="w-4 h-4"/> السيناريو واللقطات المرفقة</h3>
                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                  {activeVideo.scenes.map((scene, idx) => (
                    <div key={idx} className={`p-4 rounded-xl border transition-all ${idx === currentSceneIndex ? 'bg-pink-500/10 border-pink-500/50' : 'bg-slate-950 border-slate-800'}`}>
                      <div className="text-xs font-black text-pink-400 mb-2">المشهد {idx + 1}</div>
                      <div className="text-xs text-slate-500 mb-2 line-clamp-2" title={scene.visual_prompt}>🎥 {scene.visual_prompt}</div>
                      <div className="text-sm font-bold text-white leading-relaxed">"{scene.audio}"</div>
                    </div>
                  ))}
                </div>
              </div>

            </div>
          )}

        </div>
      </div>
    </div>
  );
}

function SettingsIcon(props) {
  return <svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
}
